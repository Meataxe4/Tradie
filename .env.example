# Copy to .env. All optional — the app runs fully offline without any of these.

# When set, triage uses the real Claude model instead of the deterministic mock.
# ANTHROPIC_API_KEY=sk-ant-...

# Optional override for the triage model id (a current, capable Claude model).
# TRIAGE_MODEL=claude-sonnet-5

# HTTP port (default 3000).
# PORT=3000
