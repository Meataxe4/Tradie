# Copy to .env. All optional — the app runs fully offline without any of these.

# When set, triage uses the real Claude model instead of the deterministic mock.
# ANTHROPIC_API_KEY=sk-ant-...

# Optional override for the triage model id (a current, capable Claude model).
# TRIAGE_MODEL=claude-sonnet-5

# HTTP port (default 3000).
# PORT=3000

# SQLite database path (default ./data/squiz.db). Data persists across restarts.
# Set to "off" or ":memory:" to run without a durable database.
# SQLITE_PATH=./data/squiz.db

# Secret used to sign session tokens (HS256). Set a long random value in
# production; a dev default is used if unset.
# AUTH_SECRET=change-me-to-a-long-random-string
